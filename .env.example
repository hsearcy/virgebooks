# Copy this file to .env (or just export variables in your shell).

# Provider choices:
#   gemini = Google Gemini API key backend (default)
#   codex  = local Codex CLI backend using your logged-in Codex subscription
VB_TEXT_PROVIDER=gemini
VB_IMAGE_PROVIDER=gemini

# Gemini setup (needed when either provider above is gemini):
# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Codex setup (needed when either provider above is codex):
# Install/login once outside the app:
#   npm install -g @openai/codex
#   codex login
# Optional tuning:
# VB_CODEX_COMMAND=codex
# VB_CODEX_MODEL=
# VB_CODEX_TIMEOUT=300
# VB_IMAGE_WORKERS=2
